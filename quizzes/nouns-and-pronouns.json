{
  "id": "nouns-and-pronouns",
  "title": "Nouns and Pronouns",
  "subject": "Language Arts",
  "category": "language-arts",
  "term": 1,
  "grade": 2,
  "timeLimit": 45,
  "icon": "📚",
  "color": "primary",
  "description": "Learn about naming words (nouns), proper nouns, singular/plural forms, and pronouns",
  "curriculum": "Jamaica NSC Grade 2 - Language Arts: Grammar & Conventions",
  "source": "Integrated Language Arts Workbook - Nouns and Pronouns",
  "nscObjectives": [
    "Identify nouns as words that name people, places, animals, and things",
    "Recognize and use proper nouns with capital letters",
    "Make singular nouns plural by adding -s or -es",
    "Identify and use plural form of irregular nouns",
    "Use collective/group nouns correctly",
    "Use personal pronouns (I, me, we, us, he, him, she, her, it, they, them)",
    "Apply correct use of pronouns I/me and my/mine"
  ],
  "sections": [
    {
      "id": "nouns-naming-words",
      "name": "Nouns - Naming Words",
      "instruction": "A noun is a word that names a person, place, animal, or thing.",
      "questions": [
        {
          "id": "nnw1",
          "type": "multiple-choice",
          "prompt": "Which word is a PERSON?",
          "options": ["Cuba", "hen", "Errol", "earrings"],
          "correct": "Errol",
          "hint": "A person is someone who can talk and walk!"
        },
        {
          "id": "nnw2",
          "type": "multiple-choice",
          "prompt": "Which word is a PLACE?",
          "options": ["dog", "Jamaica", "bed", "egg"],
          "correct": "Jamaica",
          "hint": "A place is somewhere you can go or visit."
        },
        {
          "id": "nnw3",
          "type": "multiple-choice",
          "prompt": "Which word is an ANIMAL?",
          "options": ["beach", "Morgan", "cat", "book"],
          "correct": "cat",
          "hint": "An animal is a living creature that is not a person."
        },
        {
          "id": "nnw4",
          "type": "multiple-choice",
          "prompt": "Which word is a THING?",
          "options": ["Chris", "zoo", "bat", "mat"],
          "correct": "mat",
          "hint": "A thing is an object you can touch or use."
        },
        {
          "id": "nnw5",
          "type": "multi-select",
          "prompt": "Select ALL the NOUNS in this sentence: 'The boy carries a bag to school.'",
          "options": ["The", "boy", "carries", "a", "bag", "to", "school"],
          "correct": ["boy", "bag", "school"],
          "hint": "Look for words that name people, places, or things."
        },
        {
          "id": "nnw6",
          "type": "multiple-choice",
          "prompt": "Which of these is NOT a noun?",
          "options": ["brain", "soft", "heart", "skeleton"],
          "correct": "soft",
          "hint": "'Soft' describes something - it's not a naming word."
        },
        {
          "id": "nnw7",
          "type": "multi-select",
          "prompt": "Select ALL the body part nouns:",
          "options": ["brain", "joints", "over", "blood", "under", "skull"],
          "correct": ["brain", "joints", "blood", "skull"],
          "hint": "Body parts are things inside or on your body."
        },
        {
          "id": "nnw8",
          "type": "multiple-choice",
          "prompt": "Where in your body can you find your brain?",
          "options": ["In your chest", "In your head", "In your hand", "In your foot"],
          "correct": "In your head",
          "hint": "Your brain helps you think!"
        }
      ]
    },
    {
      "id": "proper-nouns",
      "name": "Proper Nouns",
      "instruction": "A proper noun names a SPECIAL person, place, animal, or thing. Proper nouns begin with a CAPITAL LETTER.",
      "questions": [
        {
          "id": "pn1",
          "type": "multiple-choice",
          "prompt": "Which is the proper noun for 'dog'?",
          "options": ["puppy", "Bruno", "animal", "pet"],
          "correct": "Bruno",
          "hint": "A proper noun is a special name - like a pet's name!"
        },
        {
          "id": "pn2",
          "type": "multiple-choice",
          "prompt": "Which is the proper noun for 'school'?",
          "options": ["classroom", "building", "Immaculate Conception Prep", "education"],
          "correct": "Immaculate Conception Prep",
          "hint": "A proper noun is the specific name of the school."
        },
        {
          "id": "pn3",
          "type": "multiple-choice",
          "prompt": "Which is the proper noun for 'city'?",
          "options": ["town", "Brainsville", "place", "area"],
          "correct": "Brainsville",
          "hint": "A proper noun is the actual name of the city."
        },
        {
          "id": "pn4",
          "type": "multiple-choice",
          "prompt": "Which is the proper noun for 'day'?",
          "options": ["morning", "Sunday", "time", "date"],
          "correct": "Sunday",
          "hint": "Days of the week are proper nouns!"
        },
        {
          "id": "pn5",
          "type": "multiple-choice",
          "prompt": "Which is the proper noun for 'holiday'?",
          "options": ["vacation", "National Heroes Day", "celebration", "break"],
          "correct": "National Heroes Day",
          "hint": "The specific name of a holiday is a proper noun."
        },
        {
          "id": "pn6",
          "type": "multi-select",
          "prompt": "Select ALL the proper nouns:",
          "options": ["Manchester", "town", "Sally", "girl", "Spanish", "language"],
          "correct": ["Manchester", "Sally", "Spanish"],
          "hint": "Proper nouns start with capital letters and name specific things."
        },
        {
          "id": "pn7",
          "type": "multiple-choice",
          "prompt": "How do you know that a noun is a proper noun?",
          "options": [
            "It is a long word",
            "It begins with a capital letter",
            "It names an animal",
            "It is at the end of a sentence"
          ],
          "correct": "It begins with a capital letter",
          "hint": "Proper nouns always start with a capital letter!"
        },
        {
          "id": "pn8",
          "type": "multiple-choice",
          "prompt": "Which sentence has the proper nouns written correctly?",
          "options": [
            "my birthday falls on a monday.",
            "My birthday falls on a Monday.",
            "my Birthday falls on a Monday.",
            "My birthday Falls on a monday."
          ],
          "correct": "My birthday falls on a Monday.",
          "hint": "Start sentences with capitals, and days of the week need capitals too!"
        },
        {
          "id": "pn9",
          "type": "multiple-choice",
          "prompt": "Which sentence has the proper nouns written correctly?",
          "options": [
            "We go to the gordon Hill Primary School.",
            "We go to the Gordon hill Primary School.",
            "We go to the Gordon Hill Primary School.",
            "we go to the Gordon Hill Primary school."
          ],
          "correct": "We go to the Gordon Hill Primary School.",
          "hint": "All parts of a school's name are proper nouns."
        },
        {
          "id": "pn10",
          "type": "multiple-choice",
          "prompt": "Which sentence has the proper nouns written correctly?",
          "options": [
            "christmas Day is celebrated in december.",
            "Christmas day is celebrated in December.",
            "Christmas Day is celebrated in December.",
            "christmas Day is celebrated in December."
          ],
          "correct": "Christmas Day is celebrated in December.",
          "hint": "Holidays and months are proper nouns!"
        }
      ]
    },
