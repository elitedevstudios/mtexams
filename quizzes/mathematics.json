{
  "id": "mathematics",
  "title": "Mathematics",
  "subject": "Mathematics",
  "category": "mathematics",
  "term": 1,
  "grade": 2,
  "timeLimit": 35,
  "icon": "🔢",
  "color": "primary",
  "description": "Numbers, addition, subtraction, shapes, and problem solving",
  "sections": [
    {
      "id": "number-sense",
      "name": "Number Sense (0-100)",
      "instruction": "Understanding numbers and their values.",
      "questions": [
        {
          "id": "ns1",
          "type": "multiple-choice",
          "prompt": "What number comes AFTER 49?",
          "options": ["48", "50", "59", "40"],
          "correct": "50",
          "hint": "Count: 48, 49, ___"
        },
        {
          "id": "ns2",
          "type": "multiple-choice",
          "prompt": "What number comes BEFORE 30?",
          "options": ["31", "29", "20", "32"],
          "correct": "29",
          "hint": "Count backwards: 31, 30, ___"
        },
        {
          "id": "ns3",
          "type": "multiple-choice",
          "prompt": "Which number is GREATER: 45 or 54?",
          "options": ["45", "54", "They are equal"],
          "correct": "54",
          "hint": "Look at the tens place first!"
        },
        {
          "id": "ns4",
          "type": "multiple-choice",
          "prompt": "Count by 10s: 10, 20, 30, ___",
          "options": ["31", "35", "40", "50"],
          "correct": "40",
          "hint": "Add 10 each time!"
        },
        {
          "id": "ns5",
          "type": "multiple-choice",
          "prompt": "In the number 47, what does the 4 stand for?",
          "options": ["4 ones", "4 tens", "4 hundreds", "Just 4"],
          "correct": "4 tens",
          "hint": "The first digit shows how many groups of 10!"
        }
      ]
    },
    {
      "id": "addition",
      "name": "Addition",
      "instruction": "Add the numbers together.",
      "questions": [
        {
          "id": "add1",
          "type": "multiple-choice",
          "prompt": "5 + 3 = ?",
          "options": ["6", "7", "8", "9"],
          "correct": "8",
          "hint": "Count 5 fingers, then count 3 more!"
        },
        {
          "id": "add2",
          "type": "multiple-choice",
          "prompt": "7 + 6 = ?",
          "options": ["12", "13", "14", "11"],
          "correct": "13",
          "hint": "7 + 6 is the same as 7 + 3 + 3 = 10 + 3"
        },
        {
          "id": "add3",
          "type": "multiple-choice",
          "prompt": "12 + 8 = ?",
          "options": ["18", "19", "20", "21"],
          "correct": "20",
          "hint": "12 + 8 = 12 + 8 = 20"
        },
        {
          "id": "add4",
          "type": "multiple-choice",
          "prompt": "Morgan has 4 mangoes. She gets 6 more. How many does she have now?",
          "options": ["9", "10", "11", "8"],
          "correct": "10",
          "hint": "Start at 4 and count up 6 more."
        },
        {
          "id": "add5",
          "type": "text-input",
          "prompt": "9 + 5 = ?",
          "correct": "14",
          "acceptableAnswers": ["14"],
          "hint": "9 + 1 = 10, then add 4 more!"
        }
      ]
    },
    {
      "id": "subtraction",
      "name": "Subtraction",
      "instruction": "Take away (subtract) to find the difference.",
      "questions": [
        {
          "id": "sub1",
          "type": "multiple-choice",
          "prompt": "10 - 4 = ?",
          "options": ["5", "6", "7", "8"],
          "correct": "6",
          "hint": "Start at 10 and count back 4."
        },
        {
          "id": "sub2",
          "type": "multiple-choice",
          "prompt": "15 - 7 = ?",
          "options": ["7", "8", "9", "10"],
          "correct": "8",
          "hint": "15 - 5 = 10, then take away 2 more."
        },
        {
          "id": "sub3",
          "type": "multiple-choice",
          "prompt": "Marcus had 12 sweets. He ate 5. How many are left?",
          "options": ["6", "7", "8", "5"],
          "correct": "7",
          "hint": "12 take away 5 equals?"
        },
        {
          "id": "sub4",
          "type": "text-input",
          "prompt": "20 - 8 = ?",
          "correct": "12",
          "acceptableAnswers": ["12"],
          "hint": "20 - 10 = 10, but we only take 8, so add 2 back!"
        },
        {
          "id": "sub5",
          "type": "multiple-choice",
          "prompt": "18 - 9 = ?",
          "options": ["8", "9", "10", "7"],
          "correct": "9",
          "hint": "9 + 9 = 18, so 18 - 9 = ?"
        }
      ]
    },
    {
      "id": "shapes",
      "name": "Shapes",
      "instruction": "Learn about 2D and 3D shapes.",
      "questions": [
        {
          "id": "sh1",
          "type": "multiple-choice",
          "prompt": "How many sides does a TRIANGLE have?",
          "options": ["2", "3", "4", "5"],
          "correct": "3",
          "hint": "'Tri' means three!"
        },
        {
          "id": "sh2",
          "type": "multiple-choice",
          "prompt": "How many sides does a SQUARE have?",
          "options": ["3", "4", "5", "6"],
          "correct": "4",
          "hint": "A square has 4 equal sides."
        },
        {
          "id": "sh3",
          "type": "multiple-choice",
          "prompt": "A shape with NO straight sides and NO corners is a:",
          "options": ["Square", "Triangle", "Circle", "Rectangle"],
          "correct": "Circle",
          "hint": "Think of a ball or the sun!"
        },
        {
          "id": "sh4",
          "type": "multiple-choice",
          "prompt": "How many corners does a RECTANGLE have?",
          "options": ["3", "4", "5", "6"],
          "correct": "4",
          "hint": "A rectangle is like a stretched square!"
        },
        {
          "id": "sh5",
          "type": "multiple-choice",
          "prompt": "Which shape looks like a ball?",
          "options": ["Cube", "Sphere", "Cone", "Cylinder"],
          "correct": "Sphere",
          "hint": "A football and a marble are both this shape!"
        }
      ]
    },
    {
      "id": "money",
      "name": "Money (Jamaican Dollars)",
      "instruction": "Learn to count Jamaican money!",
      "questions": [
        {
          "id": "mon1",
          "type": "multiple-choice",
          "prompt": "How many $10 coins make $50?",
          "options": ["3", "4", "5", "6"],
          "correct": "5",
          "hint": "Count by 10s: 10, 20, 30, 40, 50!"
        },
        {
          "id": "mon2",
          "type": "multiple-choice",
          "prompt": "If you have two $20 coins, how much money do you have?",
          "options": ["$20", "$30", "$40", "$50"],
          "correct": "$40",
          "hint": "$20 + $20 = ?"
        },
        {
          "id": "mon3",
          "type": "multiple-choice",
          "prompt": "A patty costs $80. You pay with $100. How much change do you get?",
          "options": ["$10", "$20", "$30", "$40"],
          "correct": "$20",
          "hint": "$100 - $80 = ?"
        },
        {
          "id": "mon4",
          "type": "multiple-choice",
          "prompt": "Which has MORE money: 5 × $10 or 2 × $20?",
          "options": ["5 × $10", "2 × $20", "They are equal"],
          "correct": "5 × $10",
          "hint": "5 × $10 = $50, and 2 × $20 = $40"
        }
      ]
    },
    {
      "id": "time",
      "name": "Telling Time",
      "instruction": "Learn to read the clock.",
      "questions": [
        {
          "id": "tm1",
          "type": "multiple-choice",
          "prompt": "When the short hand is on 3 and the long hand is on 12, what time is it?",
          "options": ["12 o'clock", "3 o'clock", "6 o'clock", "9 o'clock"],
          "correct": "3 o'clock",
          "hint": "The short hand shows the hour!"
        },
        {
          "id": "tm2",
          "type": "multiple-choice",
          "prompt": "When the short hand is on 7 and the long hand is on 6, what time is it?",
          "options": ["6:30", "7:30", "7:00", "6:00"],
          "correct": "7:30",
          "hint": "When the long hand is on 6, it's half past the hour."
        },
        {
          "id": "tm3",
          "type": "multiple-choice",
          "prompt": "How many minutes are in one hour?",
          "options": ["30", "45", "60", "100"],
          "correct": "60",
          "hint": "Half an hour is 30 minutes, so a full hour is...?"
        },
        {
          "id": "tm4",
          "type": "multiple-choice",
          "prompt": "What time do you usually eat lunch?",
          "options": ["7:00 AM", "12:00 PM", "6:00 PM", "9:00 PM"],
          "correct": "12:00 PM",
          "hint": "Lunch is in the middle of the day!"
        }
      ]
    }
  ]
}
