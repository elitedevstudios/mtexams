{
  "id": "mathematics",
  "title": "Mathematics",
  "subject": "Mathematics",
  "category": "mathematics",
  "term": 1,
  "grade": 2,
  "timeLimit": 35,
  "icon": "🔢",
  "color": "primary",
  "description": "Numbers, addition, subtraction, shapes, and problem solving",
  "curriculum": "Jamaica NSC Grade 2 - Mathematics Strands: Number (0-100), Operations, Measurement, Geometry, Statistics",
  "nscObjectives": [
    "Compare relative sizes of sets (more, less, same as)",
    "Identify sets with same number of members (equivalent sets)",
    "Partition sets into groups and put back together",
    "Count and group objects into tens and hundreds up to 999",
    "Read and write numerals and number words to 999",
    "Interpret 2 and 3-digit numerals using place value (hundreds, tens, ones)",
    "Use expanded notation for 2 and 3-digit numbers",
    "Compare and order numbers on number line",
    "Add and subtract within 20 with fluency",
    "Solve word problems with addition and subtraction",
    "Tell time to hour and half-hour",
    "Count and use Jamaican currency",
    "Identify 2D shapes (circle, triangle, square, rectangle)",
    "Identify 3D shapes (sphere, cube, cone, cylinder)"
  ],
  "sections": [
    {
      "id": "number-sense",
      "name": "Number Sense (0-100)",
      "instruction": "Understanding numbers and their values. NSC Standard: Count, read, and write numerals 0-100.",
      "questions": [
        {
          "id": "ns1",
          "type": "multiple-choice",
          "prompt": "What number comes AFTER 49?",
          "options": ["48", "50", "59", "40"],
          "correct": "50",
          "hint": "Count: 48, 49, ___"
        },
        {
          "id": "ns2",
          "type": "multiple-choice",
          "prompt": "What number comes BEFORE 30?",
          "options": ["31", "29", "20", "32"],
          "correct": "29",
          "hint": "Count backwards: 31, 30, ___"
        },
        {
          "id": "ns3",
          "type": "multiple-choice",
          "prompt": "Which number is GREATER: 45 or 54?",
          "options": ["45", "54", "They are equal"],
          "correct": "54",
          "hint": "Look at the tens place first!"
        },
        {
          "id": "ns4",
          "type": "multiple-choice",
          "prompt": "Count by 10s: 10, 20, 30, ___",
          "options": ["31", "35", "40", "50"],
          "correct": "40",
          "hint": "Add 10 each time!"
        },
        {
          "id": "ns5",
          "type": "multiple-choice",
          "prompt": "In the number 47, what does the 4 stand for?",
          "options": ["4 ones", "4 tens", "4 hundreds", "Just 4"],
          "correct": "4 tens",
          "hint": "The first digit shows how many groups of 10!"
        }
      ]
    },
    {
      "id": "addition",
      "name": "Addition",
      "instruction": "Add the numbers together.",
      "questions": [
        {
          "id": "add1",
          "type": "multiple-choice",
          "prompt": "5 + 3 = ?",
          "options": ["6", "7", "8", "9"],
          "correct": "8",
          "hint": "Count 5 fingers, then count 3 more!"
        },
        {
          "id": "add2",
          "type": "multiple-choice",
          "prompt": "7 + 6 = ?",
          "options": ["12", "13", "14", "11"],
          "correct": "13",
          "hint": "7 + 6 is the same as 7 + 3 + 3 = 10 + 3"
        },
        {
          "id": "add3",
          "type": "multiple-choice",
          "prompt": "12 + 8 = ?",
          "options": ["18", "19", "20", "21"],
          "correct": "20",
          "hint": "12 + 8 = 12 + 8 = 20"
        },
        {
          "id": "add4",
          "type": "multiple-choice",
          "prompt": "Morgan has 4 mangoes. She gets 6 more. How many does she have now?",
          "options": ["9", "10", "11", "8"],
          "correct": "10",
          "hint": "Start at 4 and count up 6 more."
        },
        {
          "id": "add5",
          "type": "text-input",
          "prompt": "9 + 5 = ?",
          "correct": "14",
          "acceptableAnswers": ["14"],
          "hint": "9 + 1 = 10, then add 4 more!"
        }
      ]
    },
    {
      "id": "subtraction",
      "name": "Subtraction",
      "instruction": "Take away (subtract) to find the difference.",
      "questions": [
        {
          "id": "sub1",
          "type": "multiple-choice",
          "prompt": "10 - 4 = ?",
          "options": ["5", "6", "7", "8"],
          "correct": "6",
          "hint": "Start at 10 and count back 4."
        },
        {
          "id": "sub2",
          "type": "multiple-choice",
          "prompt": "15 - 7 = ?",
          "options": ["7", "8", "9", "10"],
          "correct": "8",
          "hint": "15 - 5 = 10, then take away 2 more."
        },
        {
          "id": "sub3",
          "type": "multiple-choice",
          "prompt": "Marcus had 12 sweets. He ate 5. How many are left?",
          "options": ["6", "7", "8", "5"],
          "correct": "7",
          "hint": "12 take away 5 equals?"
        },
        {
          "id": "sub4",
          "type": "text-input",
          "prompt": "20 - 8 = ?",
          "correct": "12",
          "acceptableAnswers": ["12"],
          "hint": "20 - 10 = 10, but we only take 8, so add 2 back!"
        },
        {
          "id": "sub5",
          "type": "multiple-choice",
          "prompt": "18 - 9 = ?",
          "options": ["8", "9", "10", "7"],
          "correct": "9",
          "hint": "9 + 9 = 18, so 18 - 9 = ?"
        }
      ]
    },
    {
      "id": "shapes-2d",
      "name": "2D Shapes (Flat Shapes)",
      "instruction": "Learn about flat shapes - they have length and width but no depth.",
      "questions": [
        {
          "id": "sh2d1",
          "type": "multiple-choice",
          "prompt": "What shape is this?",
          "shape": "triangle",
          "options": ["Square", "Triangle", "Circle", "Rectangle"],
          "correct": "Triangle",
          "hint": "Count the sides - this shape has 3!"
        },
        {
          "id": "sh2d2",
          "type": "multiple-choice",
          "prompt": "What shape is this?",
          "shape": "circle",
          "options": ["Square", "Triangle", "Circle", "Oval"],
          "correct": "Circle",
          "hint": "This shape is perfectly round with no corners!"
        },
        {
          "id": "sh2d3",
          "type": "multiple-choice",
          "prompt": "What shape is this?",
          "shape": "square",
          "options": ["Square", "Triangle", "Circle", "Rectangle"],
          "correct": "Square",
          "hint": "All 4 sides are the same length!"
        },
        {
          "id": "sh2d4",
          "type": "multiple-choice",
          "prompt": "What shape is this?",
          "shape": "rectangle",
          "options": ["Square", "Triangle", "Circle", "Rectangle"],
          "correct": "Rectangle",
          "hint": "It has 4 sides, but 2 are longer than the others!"
        },
        {
          "id": "sh2d5",
          "type": "multiple-choice",
          "prompt": "How many sides does a TRIANGLE have?",
          "shape": "triangle",
          "options": ["2", "3", "4", "5"],
          "correct": "3",
          "hint": "'Tri' means three!"
        },
        {
          "id": "sh2d6",
          "type": "multiple-choice",
          "prompt": "How many corners does a SQUARE have?",
          "shape": "square",
          "options": ["3", "4", "5", "6"],
          "correct": "4",
          "hint": "Count each corner where two sides meet!"
        },
        {
          "id": "sh2d7",
          "type": "multiple-choice",
          "prompt": "Which shape has NO corners?",
          "shapes": ["circle", "square", "triangle"],
          "options": ["Circle", "Square", "Triangle"],
          "correct": "Circle",
          "hint": "Corners are where straight sides meet. Which shape has no straight sides?"
        },
        {
          "id": "sh2d8",
          "type": "multiple-choice",
          "prompt": "What shape is this?",
          "shape": "pentagon",
          "options": ["Square", "Pentagon", "Hexagon", "Triangle"],
          "correct": "Pentagon",
          "hint": "Count the sides - 'penta' means five!"
        },
        {
          "id": "sh2d9",
          "type": "multiple-choice",
          "prompt": "What shape is this?",
          "shape": "hexagon",
          "options": ["Pentagon", "Hexagon", "Octagon", "Square"],
          "correct": "Hexagon",
          "hint": "Count the sides - 'hexa' means six!"
        }
      ]
    },
    {
      "id": "shapes-3d",
      "name": "3D Shapes (Solid Shapes)",
      "instruction": "Learn about solid shapes - they have length, width, AND depth!",
      "questions": [
        {
          "id": "sh3d1",
          "type": "multiple-choice",
          "prompt": "What 3D shape is this?",
          "shape": "sphere",
          "options": ["Cube", "Sphere", "Cone", "Cylinder"],
          "correct": "Sphere",
          "hint": "A ball and a marble are this shape!"
        },
        {
          "id": "sh3d2",
          "type": "multiple-choice",
          "prompt": "What 3D shape is this?",
          "shape": "cube",
          "options": ["Cube", "Sphere", "Cone", "Cylinder"],
          "correct": "Cube",
          "hint": "A dice and a box are this shape - all sides are squares!"
        },
        {
          "id": "sh3d3",
          "type": "multiple-choice",
          "prompt": "What 3D shape is this?",
          "shape": "cone",
          "options": ["Cube", "Sphere", "Cone", "Cylinder"],
          "correct": "Cone",
          "hint": "An ice cream cone is this shape!"
        },
        {
          "id": "sh3d4",
          "type": "multiple-choice",
          "prompt": "What 3D shape is this?",
          "shape": "cylinder",
          "options": ["Cube", "Sphere", "Cone", "Cylinder"],
          "correct": "Cylinder",
          "hint": "A can of soup or a pipe is this shape!"
        },
        {
          "id": "sh3d5",
          "type": "multiple-choice",
          "prompt": "What 3D shape is this?",
          "shape": "pyramid",
          "options": ["Cube", "Pyramid", "Cone", "Cylinder"],
          "correct": "Pyramid",
          "hint": "The pyramids in Egypt are this shape!"
        },
        {
          "id": "sh3d6",
          "type": "multiple-choice",
          "prompt": "Which 3D shape can ROLL?",
          "shapes": ["cube", "sphere", "pyramid"],
          "options": ["Cube", "Sphere", "Pyramid"],
          "correct": "Sphere",
          "hint": "Which shape has no flat sides to stop it rolling?"
        },
        {
          "id": "sh3d7",
          "type": "multiple-choice",
          "prompt": "Which 3D shape has ALL flat faces?",
          "shapes": ["sphere", "cube", "cone"],
          "options": ["Sphere", "Cube", "Cone"],
          "correct": "Cube",
          "hint": "A cube has 6 flat square faces!"
        }
      ]
    },
    {
      "id": "money",
      "name": "Money (Jamaican Dollars)",
      "instruction": "Learn to count Jamaican money!",
      "questions": [
        {
          "id": "mon1",
          "type": "multiple-choice",
          "prompt": "How many $10 coins make $50?",
          "options": ["3", "4", "5", "6"],
          "correct": "5",
          "hint": "Count by 10s: 10, 20, 30, 40, 50!"
        },
        {
          "id": "mon2",
          "type": "multiple-choice",
          "prompt": "If you have two $20 coins, how much money do you have?",
          "options": ["$20", "$30", "$40", "$50"],
          "correct": "$40",
          "hint": "$20 + $20 = ?"
        },
        {
          "id": "mon3",
          "type": "multiple-choice",
          "prompt": "A patty costs $80. You pay with $100. How much change do you get?",
          "options": ["$10", "$20", "$30", "$40"],
          "correct": "$20",
          "hint": "$100 - $80 = ?"
        },
        {
          "id": "mon4",
          "type": "multiple-choice",
          "prompt": "Which has MORE money: 5 × $10 or 2 × $20?",
          "options": ["5 × $10", "2 × $20", "They are equal"],
          "correct": "5 × $10",
          "hint": "5 × $10 = $50, and 2 × $20 = $40"
        }
      ]
    },
    {
      "id": "time",
      "name": "Telling Time",
      "instruction": "Learn to read the clock.",
      "questions": [
        {
          "id": "tm1",
          "type": "multiple-choice",
          "prompt": "When the short hand is on 3 and the long hand is on 12, what time is it?",
          "options": ["12 o'clock", "3 o'clock", "6 o'clock", "9 o'clock"],
          "correct": "3 o'clock",
          "hint": "The short hand shows the hour!"
        },
        {
          "id": "tm2",
          "type": "multiple-choice",
          "prompt": "When the short hand is on 7 and the long hand is on 6, what time is it?",
          "options": ["6:30", "7:30", "7:00", "6:00"],
          "correct": "7:30",
          "hint": "When the long hand is on 6, it's half past the hour."
        },
        {
          "id": "tm3",
          "type": "multiple-choice",
          "prompt": "How many minutes are in one hour?",
          "options": ["30", "45", "60", "100"],
          "correct": "60",
          "hint": "Half an hour is 30 minutes, so a full hour is...?"
        },
        {
          "id": "tm4",
          "type": "multiple-choice",
          "prompt": "What time do you usually eat lunch?",
          "options": ["7:00 AM", "12:00 PM", "6:00 PM", "9:00 PM"],
          "correct": "12:00 PM",
          "hint": "Lunch is in the middle of the day!"
        },
        {
          "id": "tm5",
          "type": "multiple-choice",
          "prompt": "Look at the clock. What time does it show?",
          "image": "assets/images/icons/clock.svg",
          "imageAlt": "Clock showing 3 o'clock",
          "options": ["2 o'clock", "3 o'clock", "12 o'clock", "6 o'clock"],
          "correct": "3 o'clock",
          "hint": "The short hand points to the hour!"
        },
        {
          "id": "tm6",
          "type": "multiple-choice",
          "prompt": "Look at the clock. What time does it show?",
          "image": "assets/images/icons/clock-730.svg",
          "imageAlt": "Clock showing 7:30",
          "options": ["6:30", "7:30", "7:00", "8:30"],
          "correct": "7:30",
          "hint": "The long hand on 6 means half past!"
        }
      ]
    },
    {
      "id": "word-problems",
      "name": "Word Problems",
      "instruction": "Read carefully and solve these fun problems!",
      "questions": [
        {
          "id": "wp1",
          "type": "multiple-choice",
          "prompt": "Count the mangoes. How many are there?",
          "images": [
            "assets/images/icons/mango.svg",
            "assets/images/icons/mango.svg",
            "assets/images/icons/mango.svg",
            "assets/images/icons/mango.svg",
            "assets/images/icons/mango.svg"
          ],
          "imagesLayout": "row",
          "options": ["3", "4", "5", "6"],
          "correct": "5",
          "hint": "Count each mango one by one!"
        },
        {
          "id": "wp2",
          "type": "multiple-choice",
          "prompt": "Morgan has 3 apples. Her mother gives her 4 more. How many apples does Morgan have now?",
          "images": [
            "assets/images/icons/apple.svg",
            "assets/images/icons/apple.svg",
            "assets/images/icons/apple.svg",
            "assets/images/icons/apple.svg",
            "assets/images/icons/apple.svg",
            "assets/images/icons/apple.svg",
            "assets/images/icons/apple.svg"
          ],
          "imagesLayout": "row",
          "options": ["5", "6", "7", "8"],
          "correct": "7",
          "hint": "3 + 4 = ?"
        },
        {
          "id": "wp3",
          "type": "multiple-choice",
          "prompt": "There are 8 bananas. Marcus eats 3. How many bananas are left?",
          "options": ["4", "5", "6", "11"],
          "correct": "5",
          "hint": "8 - 3 = ? (Take away means subtract!)"
        },
        {
          "id": "wp4",
          "type": "multiple-choice",
          "prompt": "Count the oranges in each group. Which group has MORE?",
          "images": [
            {"src": "assets/images/icons/orange.svg", "label": "Group A"},
            {"src": "assets/images/icons/orange.svg", "label": ""},
            {"src": "assets/images/icons/orange.svg", "label": ""},
            {"src": "assets/images/icons/orange.svg", "label": "Group B"},
            {"src": "assets/images/icons/orange.svg", "label": ""},
            {"src": "assets/images/icons/orange.svg", "label": ""},
            {"src": "assets/images/icons/orange.svg", "label": ""},
            {"src": "assets/images/icons/orange.svg", "label": ""}
          ],
          "imagesLayout": "grid",
          "options": ["Group A (3 oranges)", "Group B (5 oranges)", "They are equal"],
          "correct": "Group B (5 oranges)",
          "hint": "Count each group. 3 or 5 - which is more?"
        },
        {
          "id": "wp5",
          "type": "text-input",
          "prompt": "There are 6 children in the class. 4 more children join. How many children are there now?",
          "correct": "10",
          "acceptableAnswers": ["10", "ten"],
          "hint": "6 + 4 = ?"
        },
        {
          "id": "wp6",
          "type": "multiple-choice",
          "prompt": "A juice box costs $25. A patty costs $80. How much do they cost together?",
          "options": ["$95", "$100", "$105", "$110"],
          "correct": "$105",
          "hint": "$25 + $80 = ?"
        }
      ]
    },
    {
      "id": "patterns",
      "name": "Patterns & Sequences",
      "instruction": "Find the pattern and complete the sequence!",
      "questions": [
        {
          "id": "pat1",
          "type": "multiple-choice",
          "prompt": "What comes next? 2, 4, 6, 8, ___",
          "options": ["9", "10", "11", "12"],
          "correct": "10",
          "hint": "Count by 2s!"
        },
        {
          "id": "pat2",
          "type": "multiple-choice",
          "prompt": "What comes next? 5, 10, 15, 20, ___",
          "options": ["21", "22", "25", "30"],
          "correct": "25",
          "hint": "Count by 5s!"
        },
        {
          "id": "pat3",
          "type": "multiple-choice",
          "prompt": "What comes next? 10, 20, 30, 40, ___",
          "options": ["45", "50", "55", "60"],
          "correct": "50",
          "hint": "Count by 10s!"
        },
        {
          "id": "pat4",
          "type": "multiple-choice",
          "prompt": "What shape comes next? ⭐ ❤️ ⭐ ❤️ ⭐ ___",
          "options": ["⭐", "❤️", "🔵", "🟢"],
          "correct": "❤️",
          "hint": "The pattern repeats: star, heart, star, heart..."
        },
        {
          "id": "pat5",
          "type": "multiple-choice",
          "prompt": "What number is missing? 1, 2, ___, 4, 5",
          "options": ["0", "3", "6", "7"],
          "correct": "3",
          "hint": "Count: 1, 2, ?, 4, 5"
        }
      ]
    }
  ]
}
